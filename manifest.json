{
  "manifest_version": 3,
  "name": "AI Autocomplete",
  "description": "AI-powered autocomplete for any website.",
  "version": "1.0.0",

  "permissions": [
    "activeTab",
    "storage"
  ],

"host_permissions": [
  "<all_urls>",
  "https://api.groq.com/*"
],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}